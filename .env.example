# ============================================================
# Frontend (public — exposed to browser)
# ============================================================
# Browser Maps JS API key. Restrict by HTTP referrer in Google Cloud Console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Maps map ID — required for AdvancedMarkerElement (create in Google Cloud Console)
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

# ============================================================
# Frontend (server-only — never exposed to browser)
# ============================================================
# FastAPI backend URL. Never use NEXT_PUBLIC_ prefix.
BACKEND_URL=

# ============================================================
# Backend
# ============================================================
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=          # Service role — bypasses RLS, never log or expose

# Separate from browser key. Restrict by Render outbound IP in Google Cloud Console.
GOOGLE_PLACES_API_KEY=

OPENAI_API_KEY=
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=               # Brave Web Search API subscription token

FRONTEND_URL=                       # Exact Vercel URL for CORS allow_origins

# Admin key for /regions/* routes (optional — leave empty to disable)
ADMIN_KEY=

# ============================================================
# Tunable thresholds (optional — these are the defaults)
# ============================================================
PIN_SCORE_THRESHOLD=6.0
PIN_LAPTOP_CONFIDENCE_THRESHOLD=0.7
NEARBY_SEARCH_RADIUS_METERS=1500
PLACE_RESOLVER_SIMILARITY_THRESHOLD=0.85
PLACE_RESOLVER_DISTANCE_THRESHOLD_METERS=300
